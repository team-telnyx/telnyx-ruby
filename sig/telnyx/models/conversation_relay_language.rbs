        transcription_engine: Telnyx::Models::ConversationRelayLanguage::transcription_engine,
        transcription_engine_config: ::Hash[Symbol, top],
        transcription_provider: String,
        tts_provider: String,
        voice: String,
        voice_settings: Telnyx::Models::ConversationRelayLanguage::voice_settings
      }

    class ConversationRelayLanguage < Telnyx::Internal::Type::BaseModel
      attr_accessor language: String

      attr_reader speech_model: String?

      def speech_model=: (String) -> String

      attr_reader transcription_engine: Telnyx::Models::ConversationRelayLanguage::transcription_engine?

      def transcription_engine=: (
        Telnyx::Models::ConversationRelayLanguage::transcription_engine
      ) -> Telnyx::Models::ConversationRelayLanguage::transcription_engine

      attr_reader transcription_engine_config: ::Hash[Symbol, top]?

      def transcription_engine_config=: (
        ::Hash[Symbol, top]
      ) -> ::Hash[Symbol, top]

      attr_reader transcription_provider: String?

      def transcription_provider=: (String) -> String

      attr_reader tts_provider: String?

      def tts_provider=: (String) -> String

      attr_reader voice: String?

      def voice=: (String) -> String

      attr_reader voice_settings: Telnyx::Models::ConversationRelayLanguage::voice_settings?

      def voice_settings=: (
        Telnyx::Models::ConversationRelayLanguage::voice_settings
      ) -> Telnyx::Models::ConversationRelayLanguage::voice_settings

      def initialize: (
        language: String,
        ?speech_model: String,
        ?transcription_engine: Telnyx::Models::ConversationRelayLanguage::transcription_engine,
        ?transcription_engine_config: ::Hash[Symbol, top],
        ?transcription_provider: String,
        ?tts_provider: String,
        ?voice: String,
        ?voice_settings: Telnyx::Models::ConversationRelayLanguage::voice_settings
      ) -> void

      def to_hash: -> {
        language: String,
        speech_model: String,
        transcription_engine: Telnyx::Models::ConversationRelayLanguage::transcription_engine,
        transcription_engine_config: ::Hash[Symbol, top],
        transcription_provider: String,
        tts_provider: String,
        voice: String,
        voice_settings: Telnyx::Models::ConversationRelayLanguage::voice_settings
      }

      type transcription_engine =
        :Google
        | :Telnyx
        | :Deepgram
        | :Azure
        | :xAI
        | :AssemblyAI
        | :Speechmatics
        | :Soniox
        | :A
        | :B

      module TranscriptionEngine
        extend Telnyx::Internal::Type::Enum

        GOOGLE: :Google
        TELNYX: :Telnyx
        DEEPGRAM: :Deepgram
        AZURE: :Azure
        X_AI: :xAI
        ASSEMBLY_AI: :AssemblyAI
        SPEECHMATICS: :Speechmatics
        SONIOX: :Soniox
        A: :A
