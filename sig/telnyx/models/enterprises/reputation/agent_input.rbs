module Telnyx
  module Models
    module Enterprises
      module Reputation
        type agent_input =
          {
            administrative_area: String,
            city: String,
            contact_email: String,
            contact_name: String,
            contact_phone: String,
            contact_title: String,
            country: String,
            legal_name: String,
            postal_code: String,
            street_address: String,
            dba: String?,
            extended_address: String?
          }

        class AgentInput < Telnyx::Internal::Type::BaseModel
          attr_accessor administrative_area: String

          attr_accessor city: String

          attr_accessor contact_email: String

          attr_accessor contact_name: String

          attr_accessor contact_phone: String

          attr_accessor contact_title: String

          attr_accessor country: String

          attr_accessor legal_name: String

          attr_accessor postal_code: String

          attr_accessor street_address: String

          attr_accessor dba: String?

          attr_accessor extended_address: String?

          def initialize: (
            administrative_area: String,
            city: String,
            contact_email: String,
            contact_name: String,
            contact_phone: String,
            contact_title: String,
            country: String,
            legal_name: String,
            postal_code: String,
            street_address: String,
            ?dba: String?,
            ?extended_address: String?
          ) -> void

          def to_hash: -> {
            administrative_area: String,
            city: String,
            contact_email: String,
            contact_name: String,
            contact_phone: String,
            contact_title: String,
            country: String,
            legal_name: String,
            postal_code: String,
            street_address: String,
            dba: String?,
            extended_address: String?
          }
        end
      end
    end
  end
end
