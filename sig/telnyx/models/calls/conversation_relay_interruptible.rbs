module Telnyx
  module Models
    module Calls
      type conversation_relay_interruptible = :none | :any | :speech | :dtmf

      module ConversationRelayInterruptible
        extend Telnyx::Internal::Type::Enum

        NONE: :none
        ANY: :any
        SPEECH: :speech
        DTMF: :dtmf

        def self?.values: -> ::Array[Telnyx::Models::Calls::conversation_relay_interruptible]
      end
    end
  end
end
