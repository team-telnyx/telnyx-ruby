module Telnyx
  module Models
    module PortoutEvent = Portouts::PortoutEvent

    module Portouts
      type portout_event =
        Telnyx::Portouts::WebhookPortoutStatusChanged
        | Telnyx::Portouts::WebhookPortoutNewComment
        | Telnyx::Portouts::WebhookPortoutFocDateChanged

      module PortoutEvent
        extend Telnyx::Internal::Type::Union

        def self?.variants: -> ::Array[Telnyx::Models::Portouts::portout_event]
      end
    end
  end
end
