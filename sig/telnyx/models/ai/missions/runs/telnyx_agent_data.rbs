module Telnyx
  module Models
    module AI
      module Missions
        module Runs
          type telnyx_agent_data =
            { created_at: Time, run_id: String, telnyx_agent_id: String }

          class TelnyxAgentData < Telnyx::Internal::Type::BaseModel
            attr_accessor created_at: Time

            attr_accessor run_id: String

            attr_accessor telnyx_agent_id: String

            def initialize: (
              created_at: Time,
              run_id: String,
              telnyx_agent_id: String
            ) -> void

            def to_hash: -> {
              created_at: Time,
              run_id: String,
              telnyx_agent_id: String
            }
          end
        end
      end
    end
  end
end
