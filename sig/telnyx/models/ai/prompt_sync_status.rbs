module Telnyx
  module Models
    module AI
      type prompt_sync_status = :enabled | :disabled

      module PromptSyncStatus
        extend Telnyx::Internal::Type::Enum

        ENABLED: :enabled
        DISABLED: :disabled

        def self?.values: -> ::Array[Telnyx::Models::AI::prompt_sync_status]
      end
    end
  end
end
