module Telnyx
  module Resources
    class TermsOfService
      attr_reader number_reputation: Telnyx::Resources::TermsOfService::NumberReputation

      attr_reader agreements: Telnyx::Resources::TermsOfService::Agreements

      attr_reader branded_calling: Telnyx::Resources::TermsOfService::BrandedCalling

      def retrieve_info: (
        ?product_type: Telnyx::Models::TermsOfService::tos_product_type,
        ?request_options: Telnyx::request_opts
      ) -> Telnyx::Models::TermsOfServiceRetrieveInfoResponse

      def retrieve_status: (
        ?product_type: Telnyx::Models::TermsOfService::tos_product_type,
        ?request_options: Telnyx::request_opts
      ) -> Telnyx::Models::TermsOfServiceRetrieveStatusResponse

      def initialize: (client: Telnyx::Client) -> void
    end
  end
end
