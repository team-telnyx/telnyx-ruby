module Telnyx
  module Resources
    class AI
      class Assistants
        class Tags
          def list: (
            ?request_options: Telnyx::request_opts
          ) -> Telnyx::AI::Assistants::TagsResponse

          def add: (
            String assistant_id,
            tag: String,
            ?request_options: Telnyx::request_opts
          ) -> Telnyx::AI::Assistants::TagsResponse

          def remove: (
            String tag,
            assistant_id: String,
            ?request_options: Telnyx::request_opts
          ) -> Telnyx::AI::Assistants::TagsResponse

          def initialize: (client: Telnyx::Client) -> void
        end
