module Telnyx
  module Resources
    class AI
      attr_reader assistants: Telnyx::Resources::AI::Assistants

      attr_reader audio: Telnyx::Resources::AI::Audio

      attr_reader chat: Telnyx::Resources::AI::Chat

      attr_reader clusters: Telnyx::Resources::AI::Clusters

      attr_reader conversations: Telnyx::Resources::AI::Conversations

      attr_reader embeddings: Telnyx::Resources::AI::Embeddings

      attr_reader fine_tuning: Telnyx::Resources::AI::FineTuning

      attr_reader integrations: Telnyx::Resources::AI::Integrations

      attr_reader mcp_servers: Telnyx::Resources::AI::McpServers

      attr_reader missions: Telnyx::Resources::AI::Missions

      attr_reader openai: Telnyx::Resources::AI::OpenAI

      attr_reader tools: Telnyx::Resources::AI::Tools

      def create_response_deprecated: (
        response_request: ::Hash[Symbol, top],
        ?request_options: Telnyx::request_opts
      ) -> Telnyx::Models::ai_create_response_deprecated_response

      def retrieve_conversation_histories: (
        q: String,
        ?filter_ingested_at_gte: Time,
        ?filter_ingested_at_lte: Time,
        ?filter_record_created_at_gte: Time,
        ?filter_record_created_at_lte: Time,
        ?filter_record_id: String,
        ?filter_region_in: String,
        ?filter_retention: String,
        ?filter_user_id: String,
        ?min_score: Float,
        ?page_number: Integer,
        ?page_size: Integer,
        ?region: Telnyx::Models::AIRetrieveConversationHistoriesParams::region,
        ?request_options: Telnyx::request_opts
      ) -> Telnyx::Models::AIRetrieveConversationHistoriesResponse

      def retrieve_models: (
        ?request_options: Telnyx::request_opts
      ) -> Telnyx::ModelsResponse

      def summarize: (
        bucket: String,
        filename: String,
        ?system_prompt: String,
        ?request_options: Telnyx::request_opts
      ) -> Telnyx::Models::AISummarizeResponse

      def initialize: (client: Telnyx::Client) -> void
    end
  end
end
